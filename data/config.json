  "filtering": {
    "ai_score_threshold": 8.0,
    "time_window_hours": 24
  },
  "webhooks": [
    {
      "enabled": true,
      "url_env": "TELEGRAM_WEBHOOK_URL",
      "delivery": "items_only",
      "platform": "telegram",
      "layout": "markdown",
      "languages": ["zh"],
      "category_filter": ["dependency-risk"],
      "score_threshold_override": 7.0,
      "request_body": {
        "chat_id": "6855688015",
        "text": "#{message_title}\n\n#{summary}"
      },
      "headers": ""
    }
  ],
  "webhook": {
    "enabled": true,
    "url_env": "TELEGRAM_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "first",
    "platform": "telegram",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": ["zh"],
    "request_body": {
      "chat_id": "6855688015",
      "text": "#{message_title}\n\n#{summary}"
    },
    "headers": ""
  }
