{
  "version": "1.0",
  "ai": {
    "provider": "ali",
    "model": "qwen3.6-plus",
    "api_key_env": "DASHSCOPE_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "languages": ["zh", "en"]
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "sgl-project",
        "repo": "sglang",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "triton-lang",
        "repo": "triton",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 150
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "GitHub Trending - Daily",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending"
      },
      {
        "name": "LWN.net",
        "url": "https://lwn.net/headlines/full_text?key=${LWN_KEY}",
        "enabled": false,
        "category": "linux-kernel"
      },
      {
        "name": "抖音电商规则中心",
        "url": "https://rsshub.rssforever.com/douyin/user/MS4wLjABAAAARcAHmmF9mAG3JEixq_CdP72APhBlGlLVbN-1eBcPqao",
        "enabled": false,
        "category": "compliance-ecommerce"
      },
      {
        "name": "市监局-网络交易监督",
        "url": "https://rsshub.rssforever.com/gov/samr/news/6ac05b4dbd4e41c69f4529262540459b",
        "enabled": false,
        "category": "compliance-regulation"
      },
      {
        "name": "市监局-反不正当竞争",
        "url": "https://rsshub.rssforever.com/gov/samr/news/c5d2b1b273b545cfbc6f874f670654ab",
        "enabled": false,
        "category": "compliance-regulation"
      },
      {
        "name": "网信中国（CAC）",
        "url": "https://rsshub.rssforever.com/wechat/msghistory/wangxinzhongguo",
        "enabled": false,
        "category": "compliance-internet"
      },
      {
        "name": "广电总局公告公示",
        "url": "https://rsshub.rssforever.com/gov/nrta/news/113",
        "enabled": true,
        "category": "compliance-broadcast"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        }
      ],
      "users": [],
      "fetch_comments": 10
    },
    "telegram": {
      "enabled": true,
      "channels": [
        {
          "channel": "zaihuapd",
          "enabled": true,
          "fetch_limit": 20
        },
        {
          "channel": "cdtchinesefeed",
          "enabled": true,
          "fetch_limit": 10
        },
        {
          "channel": "https1024",
          "enabled": true,
          "fetch_limit": 10
        }
      ]
    },
    "twitter": {
      "enabled": false,
      "users": ["karpathy", "roifex"],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    }
  },
  "filtering": {
    "ai_score_threshold": 8.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": true,
    "url_env": "TELEGRAM_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "first",
    "platform": "telegram",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": ["zh"],
    "request_body": {
      "chat_id": "6855688015",
      "text": "#{message_title}\n\n#{summary}"
    },
    "headers": ""
  }
}
